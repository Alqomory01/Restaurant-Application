# Postgres
# HOST/PORT here are for container-to-container traffic inside Docker Compose
# (backend -> db over the internal network, Postgres's real port 5432). If you
# run the backend natively on your machine instead (see README's "Local
# (non-Docker) backend dev"), use POSTGRES_HOST=localhost and the *host-mapped*
# port from docker-compose.yml's `ports:` on the db service (5433, remapped
# from 5432 to avoid clashing with a locally installed Postgres) — not this file.
POSTGRES_DB=mise_erp
POSTGRES_USER=mise
POSTGRES_PASSWORD=mise
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Django
# Generate your own with:
#   cd backend && ./.venv/Scripts/python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# Do not reuse this placeholder — it's intentionally short so Django's own
# InsecureKeyLengthWarning reminds you to replace it if you forget.
DJANGO_SECRET_KEY=replace-me-generate-your-own-50-char-key
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Next.js
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
